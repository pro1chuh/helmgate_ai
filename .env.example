# -------------------------------------------------------
# Helm — конфигурация
# -------------------------------------------------------

# Режим деплоя:
#   cloud → NVIDIA NIM + Groq (по умолчанию)
#   local → только Ollama (air-gapped, 152-ФЗ)
DEPLOYMENT_MODE=cloud

# JWT (сгенерируй случайную строку: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-random-64-char-string

# -------------------------------------------------------
# Cloud провайдеры (нужны только в DEPLOYMENT_MODE=cloud)
# -------------------------------------------------------

# NVIDIA NIM — https://build.nvidia.com (LLM, Vision, ImageGen, Embeddings)
NVIDIA_API_KEY=nvapi-...

# Groq — https://console.groq.com (ASR через Whisper)
GROQ_API_KEY=gsk_...

# -------------------------------------------------------
# Local (нужны только в DEPLOYMENT_MODE=local)
# -------------------------------------------------------

# Ollama запускается автоматически через docker-compose
# Модели нужно скачать вручную:
#   docker exec helm-ollama-1 ollama pull llama3.2
#   docker exec helm-ollama-1 ollama pull llava
#   docker exec helm-ollama-1 ollama pull nomic-embed-text

# -------------------------------------------------------
# Опционально — переопределение моделей
# -------------------------------------------------------
# CLOUD_MODEL_TEXT=meta/llama-4-scout-17b-16e-instruct
# LOCAL_MODEL_TEXT=llama3.2
