DEPLOYMENT_MODE=cloud
SECRET_KEY=change-this-to-a-random-64-char-string

# OpenRouter-совместимый провайдер — все LLM модели
# routerai.ru (RU-прокси) или openrouter.ai
OPENROUTER_API_KEY=sk-...
OPENROUTER_BASE_URL=https://routerai.ru/api/v1

# Groq — только для ASR/Whisper (https://console.groq.com)
GROQ_API_KEY=gsk_...

# -------------------------------------------------------
# Local режим (DEPLOYMENT_MODE=local, air-gapped, 152-ФЗ)
# -------------------------------------------------------
# Ollama запускается автоматически через docker-compose
# Модели нужно скачать вручную:
#   docker exec helm-ollama-1 ollama pull llama3.2
#   docker exec helm-ollama-1 ollama pull llava
#   docker exec helm-ollama-1 ollama pull nomic-embed-text

# -------------------------------------------------------
# Опционально — переопределение моделей
# -------------------------------------------------------
# CLOUD_MODEL_TEXT=anthropic/claude-3.7-sonnet
# CLOUD_MODEL_CODE=qwen/qwen-2.5-coder-32b-instruct
# CLOUD_MODEL_REASONING=deepseek/deepseek-r1
